{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/live-aum/route.ts": { "maxDuration": 30 },
    "src/app/api/live-aum/[amcSlug]/route.ts": { "maxDuration": 30 },
    "src/app/api/admin/upload/route.ts": { "maxDuration": 60 },
    "src/app/api/admin/sync-instruments/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/daily-snapshot/route.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron/daily-snapshot",
      "schedule": "35 10 * * 1-5"
    }
  ]
}
