# Neon Postgres connection string
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Shared secret required in the 'x-admin-secret' header for all /api/admin/* routes and the /admin page
ADMIN_SECRET=

# DHAN client id (static, does not rotate)
DHAN_CLIENT_ID=

# Note: the DHAN *access token* is NOT stored here — it rotates every ~24h and is
# stored in the app_settings DB table instead, updatable via /admin without a redeploy.

# Sent by Vercel Cron as a Bearer token to authenticate calls to /api/cron/daily-snapshot
CRON_SECRET=
