# Neon Postgres connection string
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# DHAN client id — optional fallback default. Once a client ID is saved from /admin, the
# database value (app_settings table) takes precedence over this env var permanently.
DHAN_CLIENT_ID=

# Note: neither the DHAN *access token* nor, once saved, the client ID above live here in
# practice — both rotate/change from the app_settings DB table instead, updatable together
# via /admin without a redeploy.

# Sent by Vercel Cron as a Bearer token to authenticate calls to /api/cron/daily-snapshot
CRON_SECRET=

# Finnhub free-tier API key — used to price US-listed holdings (ISIN search + quote).
# Get one at https://finnhub.io/register (no credit card required).
FINNHUB_API_KEY=
