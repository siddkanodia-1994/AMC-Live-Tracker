# Neon Postgres connection string
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# Shared secret required in the 'x-admin-secret' header for /admin and all /api/admin/* routes
ADMIN_SECRET=

# Encrypts the DHAN token/client ID before they're written to the app_settings table (AES-256-GCM).
# Generate one with: openssl rand -hex 32
# IMPORTANT: this must be the SAME value everywhere that talks to the same database (local
# .env.local and every Vercel environment) -- local dev and production point at the same Neon
# DB, so a value encrypted with one key can't be decrypted with a different one. Back it up
# somewhere safe: losing/rotating it makes every already-encrypted app_settings row unreadable
# (legacy plaintext rows saved before this existed are unaffected either way).
SETTINGS_ENCRYPTION_KEY=

# DHAN client id — optional fallback default. Once a client ID is saved from /admin, the
# database value (app_settings table) takes precedence over this env var permanently.
DHAN_CLIENT_ID=

# Note: neither the DHAN *access token* nor, once saved, the client ID above live here in
# practice — both rotate/change from the app_settings DB table instead, updatable together
# via /admin without a redeploy. Both are encrypted at rest using SETTINGS_ENCRYPTION_KEY above.

# Sent by Vercel Cron as a Bearer token to authenticate calls to /api/cron/daily-snapshot
CRON_SECRET=

# Finnhub free-tier API key — used to price US-listed holdings (ISIN search + quote).
# Get one at https://finnhub.io/register (no credit card required).
FINNHUB_API_KEY=
